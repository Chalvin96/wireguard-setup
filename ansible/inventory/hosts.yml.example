all:
  vars:
    ansible_user: deploy
    ansible_ssh_private_key_file: ~/.ssh/id_ed25519
  children:
    ingress:
      hosts:
        ingress-01:
          ansible_host: 1.2.3.4          # replace with real VPS public IP
    edge:
      hosts:
        edge-01:
          ansible_host: 192.168.1.x      # replace with edge node LAN IP
    monitoring:
      hosts:
        monitoring-01:
          ansible_host: 192.168.1.x      # replace with monitoring node LAN IP
