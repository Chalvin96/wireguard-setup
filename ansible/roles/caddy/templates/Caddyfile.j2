# Managed by Ansible — do not edit manually
# Site blocks go in /etc/caddy/conf.d/*.caddy
{
    admin {{ edge_ip }}:2019
    metrics

    servers {
        protocols h1 h2 h3
        listener_wrappers {
            proxy_protocol {
                timeout 2s
                allow {{ wireguard_server_ip }}/32
            }
            tls
        }
    }
}

# Reusable JSON access logging — import in site blocks
(access_log) {
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 14
        }
        format json
    }
}

import /etc/caddy/conf.d/*.caddy
