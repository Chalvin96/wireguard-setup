services:
  crowdsec-blocklist-import:
    image: {{ crowdsec_blocklist_image }}
    container_name: crowdsec-blocklist-import
    restart: unless-stopped
    network_mode: host
    environment:
      CROWDSEC_URL: "http://127.0.0.1:{{ crowdsec_lapi_port }}"
      CROWDSEC_LOGIN: "blocklist-import"
      CROWDSEC_PASSWORD: "{{ vault_crowdsec_machine_password }}"
      INTERVAL: "{{ crowdsec_blocklist_interval }}"
      LISTS: "{{ crowdsec_blocklist_feeds }}"
    mem_limit: 256m
