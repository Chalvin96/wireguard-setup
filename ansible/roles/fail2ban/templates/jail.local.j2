# Managed by Ansible
[DEFAULT]
bantime.increment = true
bantime.multipliers = 1 5 30 60 300
bantime  = {{ fail2ban_ban_base }}
findtime = {{ fail2ban_findtime }}
backend  = auto

[sshd]
enabled   = true
port      = ssh
logpath   = %(sshd_log)s
maxretry  = 3
banaction = nftables[type=allports]

{% if 'edge' in group_names %}
[caddy-scanner]
enabled  = true
filter   = caddy-scanner
logpath  = /var/log/caddy/access.log
maxretry = {{ fail2ban_scanner_maxretry }}
action   = vps-ban[vps_ip="{{ ingress_ip }}"]

[caddy-404]
enabled  = true
filter   = caddy-404
logpath  = /var/log/caddy/access.log
maxretry = {{ fail2ban_flood_maxretry }}
action   = vps-ban[vps_ip="{{ ingress_ip }}"]
{% endif %}
