# Managed by Ansible
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: caddy
    static_configs:
      - targets:
          - "{{ minipc_lan_ip }}:2019"

  - job_name: node-exporter
    static_configs:
      - targets:
          - "localhost:{{ node_exporter_port }}"
