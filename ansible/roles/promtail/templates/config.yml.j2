# Managed by Ansible
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://{{ monitoring_ip }}:{{ loki_port }}/loki/api/v1/push

scrape_configs:
  - job_name: caddy
    static_configs:
      - targets:
          - localhost
        labels:
          job: caddy
          host: "{{ inventory_hostname }}"
          __path__: /var/log/caddy/access.log
    pipeline_stages:
      - json:
          expressions:
            status: status
            uri: request.uri
            remote_ip: request.remote_ip
            method: request.method
            ts: ts
      - labels:
          status:
          method:
      - timestamp:
          source: ts
          format: Unix

  - job_name: fail2ban
    static_configs:
      - targets:
          - localhost
        labels:
          job: fail2ban
          host: "{{ inventory_hostname }}"
          __path__: /var/log/fail2ban.log
