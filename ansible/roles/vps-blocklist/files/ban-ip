#!/bin/bash
set -e
if [[ -n "$SSH_ORIGINAL_COMMAND" ]]; then
    read -r IP TIMEOUT <<< "$SSH_ORIGINAL_COMMAND"
else
    IP="$1"
    TIMEOUT="$2"
fi
[[ "$IP" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]] \
  || { echo "Error: invalid IP '$IP'"; exit 1; }
[[ "$TIMEOUT" =~ ^[0-9]+$ ]] \
  || { echo "Error: invalid timeout '$TIMEOUT'"; exit 1; }
sudo nft add element inet blocklist banned { "$IP" timeout "${TIMEOUT}s" }
